{% extends 'base.html.twig' %}

{% block title %}
	{{ title ?? 'Portfolio Alexandre Bourlier' }}
{% endblock %}

{% block body %}
	<main class="main-page-wrapper">
		<div id="particles-js" aria-hidden="true"></div>

		<section id="home" class="rn-slide-area" aria-labelledby="home-title">
			<div class="slide slider-style-3">
				<div class="container">
					<div class="row slider-wrapper">
						<div class="order-2 order-xl-1 col-lg-12 col-xl-5 mt_lg--50 mt_md--50 mt_sm--50">
							<div class="slider-info">
								<div class="row">
									{% for user in users %}
										<div class="col-xl-12 col-lg-12 col-12">
											<section class="user-info-top" aria-labelledby="home-title">
												<div class="user-info-header">
													<div class="user" aria-hidden="true">
														<i data-feather="user" aria-hidden="true"></i>
													</div>

													<h1 id="home-title" class="title">
														Bonjour, je suis
														<span>{{ user.firstname }}
															{{ user.lastname }}</span>
													</h1>

													<p class="disc">{{ user.aPropos }}</p>
												</div>

												<div class="user-info-footer">
													<dl>
														<div class="info">
															<dt>
																<i data-feather="file" aria-hidden="true"></i>
																<span>Poste</span>
															</dt>
															<dd>{{ user.poste }}</dd>
														</div>

														<div class="info">
															<dt>
																<i data-feather="mail" aria-hidden="true"></i>
																<span>Email</span>
															</dt>
															<dd>
																<a href="mailto:{{ user.email }}">
																	{{ user.email }}
																</a>
															</dd>
														</div>

														<div class="info">
															<dt>
																<i data-feather="map-pin" aria-hidden="true"></i>
																<span>Localisation</span>
															</dt>
															<dd><address>{{ user.city }}, 37</address></dd>
														</div>
													</dl>
												</div>
											</section>
										</div>
									{% endfor %}

									<div class="col-xl-12 col-lg-12 col-12">
										<section class="user-info-bottom" aria-label="télécharger le CV">
											<p>
												Téléchargez mon CV ou contactez-moi pour discuter de votre projet.
											</p>

											<div class="button-wrapper d-flex mt-4">
												<a class="rn-btn mr--30" href="{{ asset('assets/documents/CV_2026.pdf') }}" alt="Télécharger le CV" download>
													<span>Télécharger mon CV</span>
												</a>

												<a class="rn-btn" href="{{ path('app_contact') }}" alt="Contactez-moi">
													<span>Contactez-moi</span>
												</a>
											</div>
										</section>
									</div>
								</div>
							</div>
						</div>

						<div class="order-1 order-xl-2 col-lg-12 col-xl-7">
							<div class="background-image-area">
								<div class="thumbnail-image">
									<img src="{{ asset('/assets/images/slider/alex.png') }}" alt="Portrait d’Alexandre Bourlier">
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>

		{% include 'partials/backToTop.html.twig' %}
	</main>
{% endblock %}
