<header class="rn-header haeder-default black-logo-version header--fixed header--sticky sticky">
	<section class="header-wrapper rn-popup-mobile-menu m--0 row align-items-center">
		<!-- Start Header Left -->
		<div class="col-lg-2 col-6">
			<div class="header-left">
				<div class="logo">
					<a href="{{path('app_home')}}">
						<img src={{ asset("/assets/images/logo/alex.png") }} alt="logo">
					</a>
				</div>
			</div>
		</div>
		<!-- End Header Left -->
		<!-- Start Header Center -->
		<div class="col-lg-10 col-6">
			<div class="header-center">
				<nav class="mainmenu-nav d-none d-xl-block">
					<ul class="primary-menu">
						<li class="nav-item">
							<a class="nav-link" href="{{ path('app_home') }}">Accueil</a>
						</li>
						<li class="nav-item">
							<a class="nav-link" href="{{ path('app_about') }}">A Propos</a>
						</li>
						<li class="nav-item">
							<a class="nav-link" href="{{ path('app_skills') }}">Compétences</a>
						</li>
						<li class="nav-item">
							<a class="nav-link" href="{{ path('app_project') }}">Projets</a>
						</li>
						<li class="nav-item">
							<a class="nav-link" href="{{ path('app_experience') }}">Expérience</a>
						</li>
					</ul>
				</nav>
				<!-- Start Header Right  -->
				<div class="header-right">
					<a class="rn-btn" href="{{ path('app_contact') }}">
						<span>CONTACTEZ-MOI</span>
					</a>

					<div class="hamberger-menu d-block d-xl-none">
						<i id="menuBtn" class="feather-menu humberger-menu"></i>
					</div>

					<div class="close-menu d-block">
						<span class="closeTrigger">
							<i data-feather="x"></i>
						</span>
					</div>
				</div>
				<!-- End Header Right  -->

			</div>
		</div>
		<!-- End Header Center -->
	</section>
	<!-- Start Popup Mobile Menu  -->
	<section class="popup-mobile-menu">
		<div class="inner">
			<div class="menu-top">
				<div class="menu-header">
					<a class="logo" href="{{path('app_home')}}">
						<img src={{ asset("/assets/images/logo/logo_mob.png") }} alt="Personal Portfolio">
					</a>
					<div class="close-button">
						<button class="close-menu-activation close">
							<i data-feather="x"></i>
						</button>
					</div>
				</div>
				{% for user in users %}
				<p class="discription">{{ user.aPropos }}</p>
				{% endfor %}
			</div>
			<div class="content">
				<ul class="primary-menu nav nav-pills">
					<li class="nav-item current">
						<a class="nav-link" href="{{path('app_home')}}">Accueil</a>
					</li>
					<li class="nav-item">
						<a class="nav-link" href="{{path('app_about')}}">A Propos</a>
					</li>
					<li class="nav-item">
						<a class="nav-link" href="{{path('app_skills')}}">Compétences</a>
					</li>
					<li class="nav-item">
						<a class="nav-link" href="{{path('app_project')}}">Projets</a>
					</li>
					<li class="nav-item">
						<a class="nav-link" href="{{path('app_experience')}}">Expérience</a>
					</li>
					<li class="nav-item">
						<a class="nav-link smoth-animation" href="{{ path('app_contact') }}">Me contacter</a>
					</li>

				</ul>
				<!-- social sharea area -->
				<div class="social-share-style-1 mt--40">
					<span class="title">Trouvez-moi sur</span>
					<ul class="social-share d-flex liststyle">
					{% for social in socials %}
						<li class="{{ social.icon }}">
							<a href="{{ social.url }}" target="_blank">
								<i data-feather="{{ social.icon }}"></i>
							</a>
						</li>

					{% endfor %}
					</ul>
				</div>
				<!-- end -->
			</div>
		</div>
	</section>
	<!-- End Popup Mobile Menu  -->

</header>




