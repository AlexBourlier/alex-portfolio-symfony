<!DOCTYPE html>
<html>
	<head>
		<meta charset="UTF-8">
		<title>
			{% block title %}Welcome!
			{% endblock %}
		</title>
		<meta http-equiv="x-ua-compatible" content="ie=edge">
		<meta name="robots" content="noindex, follow">
		<meta name="description" content="">
		<meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">

		<link rel="shortcut icon" type="image/x-icon" href="{{ asset('images/favicon.ico') }}">

		{% block stylesheets %}
			<link rel="stylesheet" href="{{ asset('css/vendor/bootstrap.min.css') }}">
			<link rel="stylesheet" href="{{ asset('css/vendor/slick.css') }}">
			<link rel="stylesheet" href="{{ asset('css/vendor/slick-theme.css') }}">
			<link rel="stylesheet" href="{{ asset('css/vendor/aos.css') }}">
			<link rel="stylesheet" href="{{ asset('css/plugins/feature.css') }}">
			<link rel="stylesheet" href="{{ asset('css/style.css') }}">
		{% endblock %}

		
	</head>

	<body>
		{% include 'partials/header.html.twig' %}
		{% block body %}{% endblock %}

        {% block javascripts %}
            <script src="{{ asset('js/vendor/jquery.js') }}"></script>
            <script src="{{ asset('js/vendor/bootstrap.js') }}"></script>

            <script src="{{ asset('js/vendor/jquery-one-page-nav.js') }}"></script>

            <script src="{{ asset('js/vendor/feather.min.js') }}"></script>
            <script src="{{ asset('js/vendor/slick.min.js') }}"></script>
            <script src="{{ asset('js/vendor/aos.js') }}"></script>
            <script src="{{ asset('js/vendor/wow.js') }}"></script>
            <script src="{{ asset('js/vendor/particles.js') }}"></script>

            <script src="{{ asset('js/main.js') }}"></script>
        {% endblock %}


	</body>
</html>
