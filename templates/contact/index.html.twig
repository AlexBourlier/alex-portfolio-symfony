{% extends 'base.html.twig' %}

{% block title %}
	{{ title }}
{% endblock %}

{% block body %}
	<main class="rn-resume-area rn-section-gap">
		<div id="particles-js"></div>

		<div id="contact" class="rn-contact-area experience-style-three rn-section-gap">
			<div class="container">
				<div class="row">
					<div class="col-lg-12">
						<div data-aos="fade-left" data-aos-duration="500" data-aos-delay="200" data-aos-once="true" class="rn-contact-area section-height">
							<div class="inner">
								<h5 class="title">Contactez-moi !</h5>
								<p>
									Ecrivez-moi pour toute demande d'information ou de projet,
									                                    je serai ravi d'échanger avec vous
								</p>

								{% for message in app.flashes('success') %}
									<div class="alert alert-success mb-4">
										{{ message }}
									</div>
								{% endfor %}

								{% for message in app.flashes('error') %}
									<div class="alert alert-danger mb-4">
										{{ message }}
									</div>
								{% endfor %}

								<div class="contact-form-wrapper">
									<div class="introduce">
										{{ form_start(form) }}
										<div class="row">
											<div class="col-lg-12 col-xl-6">
												<div class="form-group">
													{{ form_label(form.name) }}
													{{ form_widget(form.name) }}
													{{ form_errors(form.name) }}
												</div>
											</div>

											<div class="col-lg-12 col-xl-6">
												<div class="form-group">
													{{ form_label(form.email) }}
													{{ form_widget(form.email) }}
													{{ form_errors(form.email) }}
												</div>
											</div>

											<div class="col-lg-12">
												<div class="form-group">
													{{ form_label(form.subject) }}
													{{ form_widget(form.subject) }}
													{{ form_errors(form.subject) }}
												</div>
											</div>

											<div class="col-lg-12">
												<div class="form-group">
													{{ form_label(form.message) }}
													{{ form_widget(form.message) }}
													{{ form_errors(form.message) }}
												</div>
											</div>

											<div class="col-lg-12">
												{{ form_widget(form.submit) }}
											</div>
										</div>
										{{ form_end(form) }}
									</div>
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</main>
{% endblock %}
