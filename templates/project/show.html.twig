{% extends 'base.html.twig' %}

{% block title %}
	{{ title }}
{% endblock %}

{% block body %}
<!-- Start Portfolio area -->
<main class="rn-resume-area rn-section-gap">
    <div id="particles-js"></div>
<div class="slide slider-style-3">
	<div class="container">
		<div class="row slider-wrapper">
			<div class="col-lg-12 col-xl-12 mt_lg--50 mt_md--50 mt_sm--50">
				<div class="slider-info">

                    <div class="row">
                        <article class="col-xl-12 col-lg-12 col-12">
                            <div class="user-info-top">
                                <div class="user-info-header">
                                    <div class="user">
                                        <i data-feather="user">
                                        </i>
                                    </div>
                                    <time class="date" datetime="{{ project.year|date('Y-m-d') }}">{{ project.year|date('d M, Y') }}</time>
                                    <h1 class="title text-center mb-4">{{ project.title }}</h1>

                                    <img src="{{ project.picture }}" alt="{{project.title}}" class="img-fluid feat-img m-auto d-block">
                                </div>
                                <div class="user-info-footer">
                                    <div class="news-details">
                                        <p>{{project.description}}</p>
                                    </div>


                                </div>
                            </div>
                                    <div class="col-lg-12 text-center mt--10">
                                        <a class="rn-btn" href="{{ path('app_project') }}">
                                            <span>Retour aux projets</span>
                                        </a>
                                    </div>
                        </article>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>


</main>


{% endblock %}

