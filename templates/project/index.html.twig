{% extends 'base.html.twig' %}

{% block title %}{{ title }}{% endblock %}

{% block body %}
<!-- Start Portfolio area -->
<main class="rn-resume-area rn-section-gap">
	<div id="particles-js"></div>

<div id="portfolio" class="rn-portfolio-area rn-section-gap">
	<div class="container">
		<div class="row">
			<div class="col-lg-12">
				<div data-aos="fade-up" data-aos-duration="500" data-aos-delay="100" data-aos-once="true" class="section-title text-center">
					<span class="subtitle">Visiter mon portfolio et donner votre avis !</span>
					<h2 class="title">Mes différents projets</h2>

				</div>
			</div>
		</div>
		<div class="row mt--10">
			<div
				class="col-12 mt_experience">

				<!-- single skills -->
				{% for project in projects %}
				<div data-aos="fade-up" data-aos-duration="500" data-aos-delay="100" data-aos-once="true" class="experience-style-two">
					<div class="experience-left">
						<div class="experience-image">
							<img src="{{ project.picture }}" alt="{{project.title}}">
						</div>
						<div class="experience-center">
							<span class="date">{{project.year|date('Y')}}</span>
							<h4 class="experience-title">
								{{project.title}}
							</h4>
							<h6 class="subtitle">
								{{project.subtitle}}
							</h6>
							<p class="disc">{{ project.description }}</p>

						</div>
					</div>
					<div class="experience-right">
						<div class="experience-footer">
							<a class="rn-btn" href="{{ path('app_project_show', {'slug': project.title | replace({' ': '-'}) }) }}">
								<span>EN VOIR PLUS</span>
							</a>
						</div>
					</div>
				</div>
				{% endfor %}
				<!-- single skills -->

			</div>
		</div>
	</div>
</div>
</main>
<!-- End Experience area -->

{% endblock %}
